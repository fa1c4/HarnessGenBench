# Generated by scripts/ckgfuzzer_prepare_project.sh; placeholders are filled in results/.
config:
  project_name: "@PROJECT@"
  program_language: "c"
  fuzz_projects_dir: "@FUZZ_PROJECTS_DIR@"
  work_dir: "@WORK_DIR@"
  shared_dir: "@SHARED_DIR@"
  report_target_dir: "/src/@PROJECT@"
  time_budget: "1m"
  headers:
    - "sample.h"
    - <stddef.h>
    - <stdint.h>

llm_embedding:
  model: "ollama-nomic-embed-text"
  base_url: "@OLLAMA_BASE_URL@"

llm_analyzer:
  api_key: ""
  model: "openai-@MODEL@"
  base_url: "@OPENAI_BASE_URL@"
  temperature: 0.2

llm_coder:
  api_key: ""
  model: "openai-@MODEL@"
  base_url: "@OPENAI_BASE_URL@"
  temperature: 0.2

# Required for most LLM backends
OPENAI_API_KEY=
OPENAI_BASE_URL=
OFG_MODEL=gpt-4o-mini

# Optional Vertex / Google settings if using Gemini / Vertex models
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Runtime knobs
OFG_BENCHMARK=tinyxml2
OFG_RUN_TIMEOUT=300
OFG_TOTAL_TIMEOUT_SECONDS=600
OFG_MAX_ROUNDS=1
OFG_WORKERS=1
